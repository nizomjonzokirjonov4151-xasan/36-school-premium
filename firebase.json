{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "36 school-sistym",
    "ignore": [
      "firebase.json",
      "**/.*",
      ".git/**",
      "**/.git/**",
      "**/node_modules/**",
      ".env",
      "server.js",
      "package.json",
      "package-lock.json"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
